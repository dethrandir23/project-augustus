[configuration]
entry_symbol = "godot_augustus_init"
compatibility_minimum = "4.3"

[libraries]
linux.debug.x86_64 = "res://addons/project-augustus/libproject-augustus-godot.so"
linux.release.x86_64 = "res://addons/project-augustus/libproject-augustus-godot.so"
windows.debug.x86_64 = "res://addons/project-augustus/project-augustus-godot.dll"
windows.release.x86_64 = "res://addons/project-augustus/project-augustus-godot.dll"
macos.debug = "res://addons/project-augustus/libproject-augustus-godot.dylib"
macos.release = "res://addons/project-augustus/libproject-augustus-godot.dylib"
